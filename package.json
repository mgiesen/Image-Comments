{
	"name": "image-comments",
	"displayName": "Image Comments",
	"icon": "icon.png",
	"version": "1.7.0",
	"description": "This Visual Studio Code extension lets you easily add visual comments such as sketches or diagrams directly into your source code, improving code documentation and understanding.",
	"publisher": "mgiesen",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/mgiesen/Image-Comments.git"
	},
	"bugs": {
		"url": "https://github.com/mgiesen/Image-Comments/issues"
	},
	"homepage": "https://github.com/mgiesen/Image-Comments#readme",
	"keywords": [
		"image",
		"comments",
		"documentation",
		"diagram",
		"sketch",
		"hover",
		"tooltip"
	],
	"engines": {
		"vscode": "^1.78.0"
	},
	"categories": [
		"Programming Languages",
		"Visualization",
		"Formatters",
		"Other"
	],
	"activationEvents": [
		"onLanguage:c",
		"onLanguage:clojure",
		"onLanguage:coffeescript",
		"onLanguage:cpp",
		"onLanguage:csharp",
		"onLanguage:css",
		"onLanguage:dart",
		"onLanguage:elixir",
		"onLanguage:fsharp",
		"onLanguage:go",
		"onLanguage:groovy",
		"onLanguage:haskell",
		"onLanguage:html",
		"onLanguage:java",
		"onLanguage:javascript",
		"onLanguage:jsonc",
		"onLanguage:kotlin",
		"onLanguage:less",
		"onLanguage:lua",
		"onLanguage:matlab",
		"onLanguage:objective-c",
		"onLanguage:ocaml",
		"onLanguage:perl",
		"onLanguage:php",
		"onLanguage:powershell",
		"onLanguage:python",
		"onLanguage:r",
		"onLanguage:ruby",
		"onLanguage:rust",
		"onLanguage:sass",
		"onLanguage:scala",
		"onLanguage:scss",
		"onLanguage:shellscript",
		"onLanguage:sql",
		"onLanguage:swift",
		"onLanguage:typescript",
		"onLanguage:yaml",
		"onLanguage:vue",
		"onLanguage:glsl",
		"onLanguage:odin"
	],
	"main": "./src/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "imageComments.pasteImage",
				"title": "Image Comments: Paste Image",
				"icon": "$(file-media)"
			}
		],
		"menus": {
			"editor/context": [
				{
					"command": "imageComments.pasteImage",
					"when": "editorTextFocus && !editorReadonly",
					"group": "imageComment"
				}
			]
		},
		"configuration": {
			"type": "object",
			"title": "Image Comments",
			"properties": {
				"imageComments.pathMode": {
					"type": "string",
					"enum": [
						"relativeToFile",
						"relativeToWorkspace"
					],
					"default": "relativeToFile",
					"description": "Specifies whether the image path is relative to the file or the workspace.",
					"enumDescriptions": [
						"Image paths in comments are relative to the file.",
						"Image paths in comments are relative to the workspace."
					]
				},
				"imageComments.saveDirectory": {
					"type": "string",
					"default": "image-comments",
					"description": "Directory where pasted images are saved, relative to the workspace root."
				}
			}
		}
	},
	"scripts": {
		"test": "node --test",
		"package": "vsce package",
		"publish": "vsce publish"
	},
	"devDependencies": {
		"@types/vscode": "^1.78.0",
		"@vscode/vsce": "^3.0.0"
	}
}
